# URL of the Render backend (use http://localhost:8000 for local dev)
MINIPC_API_URL=http://localhost:8000

# Must match SYNC_API_KEY in the backend .env
SYNC_API_KEY=change-this-to-a-random-sync-key

# Optional: partial name match to find the right workbook if multiple are open
# Leave blank to use the first open workbook
EXCEL_WORKBOOK_NAME=

# How often to push (seconds). Default: 5
PUSH_INTERVAL_SECONDS=15

# Comma-separated sheet names to exclude (exact match). Leave blank to push all sheets.
EXCLUDED_SHEETS=
